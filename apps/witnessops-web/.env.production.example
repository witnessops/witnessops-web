# Public origin for metadata, sitemap, and canonical URLs.
NEXT_PUBLIC_OS_SITE_URL=https://witnessops.com

# Required runtime signing secret. Use a long random value.
WITNESSOPS_TOKEN_SIGNING_SECRET=replace-with-long-random-secret

# Token validity window in minutes.
WITNESSOPS_TOKEN_TTL_MINUTES=30

# Must be a provider-valid production sender.
WITNESSOPS_TOKEN_FROM_EMAIL=engage@witnessops.com

# Must be the real production origin. Do not use localhost in production.
WITNESSOPS_VERIFY_BASE_URL=https://witnessops.com

# Production must use a real provider. Do not use file mode in production.
WITNESSOPS_MAIL_PROVIDER=resend

# Required when WITNESSOPS_MAIL_PROVIDER=resend.
WITNESSOPS_RESEND_API_KEY=re_replace_me

# Must point to persistent storage. Do not use ephemeral container disk.
WITNESSOPS_INTAKE_STORE_DIR=/persistent/witnessops/intake-store

# Optional legacy alias for WITNESSOPS_INTAKE_STORE_DIR.
# WITNESSOPS_TOKEN_STORE_DIR=/persistent/witnessops/intake-store

# Append-only intake event ledger directory.
WITNESSOPS_TOKEN_AUDIT_DIR=/persistent/witnessops/intake-events

# Local-only. Leave unset in real production mail mode.
# WITNESSOPS_MAIL_OUTPUT_DIR=/persistent/witnessops/mail-out

# Required when WITNESSOPS_MAIL_PROVIDER=resend. Verifies inbound Resend webhook signatures.
# WITNESSOPS_RESEND_WEBHOOK_SECRET=whsec_replace_me

# Required when WITNESSOPS_MAIL_PROVIDER=m365. Verifies inbound M365 webhook signatures.
# WITNESSOPS_M365_WEBHOOK_SECRET=replace-with-m365-webhook-secret

# Optional. Governed-exposure assessment server. Leave unset to disable assessment integration.
# GES_SERVER_URL=https://ges.internal.example.com
# GES_ASSESSMENT_KEY=replace-with-assessment-key

# Control plane handoff. Required to emit scope-approved events after operator approval.
# CONTROL_PLANE_URL=https://cp.internal.example.com
# CONTROL_PLANE_API_KEY=replace-with-control-plane-api-key

# Only if admin routes are enabled in production.
# WITNESSOPS_ADMIN_SECRET=replace-with-long-random-secret
# WITNESSOPS_ADMIN_KEY_HASH=replace-with-derived-hash
