{
  "name": "witnessops-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx --test 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "test:evidence": "tsx --tsconfig ./tsconfig.json --test 'src/lib/server/*.test.ts' 'src/app/api/provider-events/**/*.test.ts'"
  },
  "dependencies": {
    "@witnessops/config": "workspace:*",
    "@witnessops/content": "workspace:*",
    "@witnessops/proof": "workspace:*",
    "@witnessops/ui": "workspace:*",
    "framer-motion": "^12.36.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svix": "^1.89.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
